<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Keep original names for Material Design compatibility -->
    <attr name="backgroundColor" format="color" />
    <attr name="surfaceColor" format="color" />
    <attr name="dividerHorizontal" format="reference|color" />

    <attr name="textColorPrimary" format="color" />
    <attr name="textColorSecondary" format="color" />
    <attr name="textColorHint" format="color" />

    <attr name="incomeColor" format="color" />
    <attr name="expenseColor" format="color" />
    <attr name="balanceColor" format="color" />

    <attr name="bottomNavIconTextColor" format="color" />
    <attr name="bottomNavSelectedColor" format="color" />
    <attr name="bottomNavBorderColor" format="color" />

    <attr name="primary_blue" format="color" />
    <attr name="secondary_green" format="color" />

    <!-- Declare these as styleable to avoid conflicts -->
    <declare-styleable name="ArthamTheme">
        <attr name="backgroundColor" />
        <attr name="surfaceColor" />
        <attr name="textColorPrimary" />
        <attr name="textColorSecondary" />
        <attr name="textColorHint" />
    </declare-styleable>
</resources>
