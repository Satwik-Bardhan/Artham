<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Artham" parent="Theme.Material3.DayNight.NoActionBar">

        <item name="android:fontFamily">@font/app_font</item>

        <!-- Material 3 Color System -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorError">@color/expense_red</item>

        <!-- M3 Surface Colors -->
        <item name="android:colorBackground">@color/backgroundColor</item>
        <item name="colorSurface">@color/surfaceColor</item>
        <item name="colorOnSurface">@color/textColorPrimary</item>
        <item name="colorOnSurfaceVariant">@color/textColorSecondary</item>
        <item name="colorOutline">@color/divider_color</item>

        <!-- Custom App-specific Attributes -->
        <item name="backgroundColor">@color/backgroundColor</item>
        <item name="surfaceColor">@color/surfaceColor</item>
        <item name="textColorPrimary">@color/textColorPrimary</item>
        <item name="textColorSecondary">@color/textColorSecondary</item>
        <item name="textColorHint">@color/textColorHint</item>
        <item name="incomeColor">@color/income_green</item>
        <item name="expenseColor">@color/expense_red</item>
        <item name="balanceColor">@color/balance_blue</item>
        <item name="dividerHorizontal">@color/divider_color</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">?attr/backgroundColor</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Other UI components -->
        <item name="bottomNavIconTextColor">@color/bottom_nav_icon_text_color</item>
        <item name="bottomNavSelectedColor">@color/bottom_nav_selected</item>
        <item name="bottomNavBorderColor">@color/bottom_nav_item_unselected_border</item>
        <item name="buttonStyle">@style/ProfessionalButton</item>
    </style>

    <style name="Theme.Artham.Violet" parent="Theme.Artham">
        <item name="colorPrimary">@color/violet_primary</item>
        <item name="colorOnPrimary">@color/violet_text</item>
        <item name="colorSecondary">@color/violet_primary</item>
        <item name="colorOnSecondary">@color/violet_text</item>

        <item name="android:colorBackground">@color/violet_bg</item>
        <item name="colorSurface">@color/violet_surface</item>
        <item name="colorOnSurface">@color/violet_text</item>
        <item name="colorOnSurfaceVariant">@color/violet_primary</item>
        <item name="colorOutline">@color/violet_divider</item>

        <item name="backgroundColor">@color/violet_bg</item>
        <item name="surfaceColor">@color/violet_surface</item>
        <item name="textColorPrimary">@color/violet_text</item>
        <item name="textColorSecondary">@color/violet_primary</item>
        <item name="textColorHint">@color/violet_divider</item>
        <item name="incomeColor">#81C784</item>
        <item name="expenseColor">#EF5350</item>
        <item name="balanceColor">@color/violet_primary</item>
        <item name="dividerHorizontal">@color/violet_divider</item>

        <item name="android:statusBarColor">?attr/backgroundColor</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="bottomNavIconTextColor">@color/violet_primary</item>
        <item name="bottomNavSelectedColor">@color/violet_text</item>
        <item name="bottomNavBorderColor">@color/violet_divider</item>
    </style>

    <style name="Theme.Artham.Dialog" parent="Theme.Artham">
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>

    <style name="ProfessionalButton" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/app_font</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

</resources>