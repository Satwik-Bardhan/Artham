<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="?attr/surfaceColor"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Transaction Details"
                    android:fontFamily="@font/app_font"
                    android:textColor="?attr/textColorPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/closeButton"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_close"
                    app:tint="?attr/textColorSecondary"
                    android:clickable="true"
                    android:focusable="true"/>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/categoryIconCard"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/backgroundColor">

                    <ImageView
                        android:id="@+id/detailCategoryIcon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:src="@drawable/ic_category_default"
                        app:tint="?attr/textColorPrimary"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/detailCategoryName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Category Name"
                    android:fontFamily="@font/app_font"
                    android:textColor="?attr/textColorSecondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/detailAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="₹0.00"
                    android:fontFamily="@font/app_font"
                    android:textColor="?attr/incomeColor"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/detailType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/rounded_tag_background"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Income"
                    android:fontFamily="@font/app_font"
                    android:textSize="12sp"
                    android:textColor="?attr/textColorPrimary"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_input_background"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_schedule"
                        app:tint="?attr/textColorSecondary"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:id="@+id/detailDateTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="May 24, 2025 • 10:30 AM"
                        android:fontFamily="@font/app_font"
                        android:textColor="?attr/textColorPrimary"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_payment"
                        app:tint="?attr/textColorSecondary"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:id="@+id/detailPaymentMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Online"
                        android:fontFamily="@font/app_font"
                        android:textColor="?attr/textColorPrimary"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/detailPartyLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_person"
                        app:tint="?attr/textColorSecondary"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:id="@+id/detailParty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="John Doe"
                        android:fontFamily="@font/app_font"
                        android:textColor="?attr/textColorPrimary"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/detailTaxLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_receipt"
                        app:tint="?attr/textColorSecondary"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:id="@+id/detailTax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tax Included: 5%"
                        android:fontFamily="@font/app_font"
                        android:textColor="?attr/textColorPrimary"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/detailTagsLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_list"
                        app:tint="?attr/textColorSecondary"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:id="@+id/detailTags"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Personal, Food"
                        android:fontFamily="@font/app_font"
                        android:textColor="?attr/textColorPrimary"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/detailLocationLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_location"
                        app:tint="?attr/textColorSecondary"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:id="@+id/detailLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Location Name"
                        android:fontFamily="@font/app_font"
                        android:textColor="?attr/textColorPrimary"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_note"
                        app:tint="?attr/textColorSecondary"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:id="@+id/detailRemark"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="This is a remark for the transaction."
                        android:fontFamily="@font/app_font"
                        android:textColor="?attr/textColorSecondary"
                        android:textSize="14sp"
                        android:textStyle="italic"/>
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/attachmentsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="Attachments"
                android:fontFamily="@font/app_font"
                android:textColor="?attr/textColorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/detailAttachmentsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/attachmentPreview"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_image"
                    android:background="@drawable/rounded_input_background"
                    android:padding="12dp"
                    app:tint="?attr/textColorSecondary"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <Button
                    android:id="@+id/btnEditTransaction"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Edit"
                    android:background="@drawable/button_primary"
                    android:textColor="@color/white"
                    android:fontFamily="@font/app_font"
                    android:textAllCaps="false"
                    app:backgroundTint="@null"/>

                <Button
                    android:id="@+id/btnDeleteTransaction"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/button_cancel_outline"
                    android:foreground="@drawable/ic_delete"
                    android:foregroundTint="?attr/expenseColor"
                    android:foregroundGravity="center"
                    app:backgroundTint="@null"/>

                <Button
                    android:id="@+id/btnShareTransaction"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/button_secondary"
                    android:foreground="@drawable/ic_share"
                    android:foregroundTint="?attr/textColorPrimary"
                    android:foregroundGravity="center"
                    app:backgroundTint="@null"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.cardview.widget.CardView>