<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="24dp"
    app:cardElevation="12dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <ImageButton
                android:id="@+id/closeButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"
                android:src="@drawable/ic_close"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/detailRemark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingExtra="4dp"
                android:text="Groceries for the week"
                android:textColor="?attr/colorOnSurface"
                android:textSize="22sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/closeButton" />

            <TextView
                android:id="@+id/detailAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-black"
                android:text="₹1,500.00"
                android:textColor="?attr/colorPrimary"
                android:textSize="34sp"
                app:layout_constraintStart_toStartOf="@id/detailRemark"
                app:layout_constraintTop_toBottomOf="@id/detailRemark" />

            <com.google.android.material.chip.Chip
                android:id="@+id/detailTypeChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Expense"
                android:textColor="?attr/colorOnSurfaceVariant"
                app:chipBackgroundColor="?attr/colorSurfaceVariant"
                app:chipMinHeight="32dp"
                app:chipStrokeWidth="0dp"
                app:layout_constraintBottom_toBottomOf="@id/detailAmount"
                app:layout_constraintStart_toEndOf="@id/detailAmount"
                app:layout_constraintTop_toTopOf="@id/detailAmount" />

            <View
                android:id="@+id/divider"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:alpha="0.2"
                android:background="?attr/colorOutline"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/detailAmount" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/metaDataContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/divider">

                <ImageView
                    android:id="@+id/iconCategory"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_category_default"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/detailCategoryName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Food &amp; Dining"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/iconCategory"
                    app:layout_constraintTop_toTopOf="@id/iconCategory" />

                <ImageView
                    android:id="@+id/iconDate"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="20dp"
                    android:src="@drawable/ic_schedule"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/detailCategoryName"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/detailDateTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="May 24, 10:30 AM"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/iconDate"
                    app:layout_constraintTop_toTopOf="@id/iconDate" />

                <ImageView
                    android:id="@+id/iconPayment"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="20dp"
                    android:src="@drawable/ic_payment"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/detailDateTime"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/detailPaymentMode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Credit Card"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/iconPayment"
                    app:layout_constraintTop_toTopOf="@id/iconPayment" />

                <ImageView
                    android:id="@+id/iconParty"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="20dp"
                    android:src="@drawable/ic_person"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/detailPaymentMode"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/detailParty"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Walmart"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/iconParty"
                    app:layout_constraintTop_toTopOf="@id/iconParty" />

                <ImageView
                    android:id="@+id/iconTags"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="20dp"
                    android:src="@drawable/ic_label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/detailParty"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/detailTags"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Weekly, Personal"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/iconTags"
                    app:layout_constraintTop_toTopOf="@id/iconTags" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <ImageView
                android:id="@+id/attachmentPreview"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/rounded_surface_variant"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_image_placeholder"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/metaDataContainer" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/attachmentPreview">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditTransaction"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Edit"
                    android:textColor="?attr/colorOnPrimary"
                    app:backgroundTint="?attr/colorPrimary"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_edit"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeleteTransaction"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="12dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_delete"
                    app:iconGravity="textStart"
                    app:iconTint="?attr/colorError"
                    app:strokeColor="?attr/colorError" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShareTransaction"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="12dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_share"
                    app:iconTint="?attr/colorOnSurface"
                    app:strokeColor="?attr/colorOutline" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</com.google.android.material.card.MaterialCardView>