<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_receipt"
            app:tint="?attr/textColorSecondary"
            android:layout_marginEnd="12dp"
            android:contentDescription="Tax Icon"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/app_font"
            android:text="Include Tax / VAT"
            android:textColor="?attr/textColorPrimary"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/taxCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="?attr/balanceColor" />
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/taxAmountLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="32dp"
        android:visibility="gone"
        android:hint="Tax Amount"
        app:hintTextColor="?attr/textColorSecondary"
        app:boxBackgroundColor="?attr/surfaceColor"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxStrokeWidth="1dp"
        app:boxStrokeColor="?attr/dividerHorizontal">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/taxAmountEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:fontFamily="@font/app_font"
            android:textColor="?attr/textColorPrimary" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>